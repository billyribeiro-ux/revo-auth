# Public (shipped to the browser). Prefix required by SvelteKit.
PUBLIC_REVO_AUTH_SERVER_URL=http://localhost:8787
PUBLIC_REVO_AUTH_APP_ID=demo-app
PUBLIC_REVO_AUTH_PUBLIC_KEY=pk_demo_replace_me

# Server-only secret (never exposed). Used by Node endpoints + admin calls.
REVO_AUTH_SECRET_KEY=sk_demo_replace_me
