<script lang="ts">
	import { PasswordField, PasswordStrengthMeter } from '@revo-auth/ui-sveltekit';
	import { auth } from '$lib/auth/client';

	let password = $state('');
	let status = $state<'idle' | 'loading' | 'done' | 'error'>('idle');

	async function onSubmit(e: SubmitEvent) {
		e.preventDefault();
		status = 'loading';
		try {
			await auth.resetPassword({ password });
			status = 'done';
		} catch {
			status = 'error';
		}
	}
</script>

<main class="auth-page">
	<h1>Reset password</h1>
	<form onsubmit={onSubmit}>
		<PasswordField bind:value={password} />
		<PasswordStrengthMeter value={password} />
		<button type="submit" disabled={status === 'loading'}>
			{status === 'loading' ? 'Saving…' : 'Save password'}
		</button>
	</form>
	{#if status === 'done'}<p>Password updated.</p>{/if}
	{#if status === 'error'}<p class="auth-error">Could not update password.</p>{/if}
</main>
